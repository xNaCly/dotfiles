

[global]
font = JetBrains Mono 11
markup = yes
plain_text = no
format = "%a\n<b>%s</b>\n%b\n%p"
sort = no
indicate_hidden = no
alignment = left
bounce_freq = 0
show_age_threshold = -1
word_wrap = yes
ignore_newline = no
stack_duplicates = yes
hide_duplicate_count = no
geometry = "250x50-13+40"
shrink = no
transparency = 25
idle_threshold = 0
monitor = 0
follow = none
sticky_history = yes
history_length = 15
show_indicators = no
line_height = 3
separator_height = 2
padding = 6
horizontal_padding = 6
separator_color = auto
startup_notification = false
dmenu = /usr/bin/dmenu -p dunst:
browser = /usr/bin/firefox -new-tab
icon_position = right
max_icon_size = 100
icon_path = /usr/share/icons/Paper/16x16/mimetypes/:/usr/share/icons/Paper/48x48/status/:/usr/share/icons/Paper/16x16/devices/:/usr/share/icons/Paper/48x48/notifications/:/usr/share/icons/Paper/48x48/emblems/
frame_width = 2
frame_color = "#BF5D47"
[shortcuts]
close = ctrl+space
close_all = ctrl+shift+space
context = ctrl+shift+period
[urgency_low]
frame_color = "#BF5D47"
foreground = "#b1cbbb"
background = "#252524"
timeout = 10
[urgency_normal]
frame_color = "#BF5D47"
foreground = "#b1cbbb"
background = "#252524"
timeout = 10
[urgency_critical]
frame_color = "#BF5D47"
foreground = "#b1cbbb"
background = "#252524"
timeout = 10
# vim: ft=cfg
