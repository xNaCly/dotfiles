# https://github.com/xnacly/dotfiles
# this config supports dynamic color setting based on the background for i3, i3status/bar, terminal (alacritty), dunst and rofi

# flags:
set $browser "brave"
set $term "alacritty"
set $wallpaper_path ~/.config/wallpapers
set $font JetBrains Mono Nerd Font
set $font_size 10
set $gaps 10
set $Locker i3lock --color=000000 && sleep 1
hide_edge_borders smart
focus_follows_mouse no

set $background "#1e1d2f"
set $background_trans "#1e1d2f60"
set $background2 "#1E1E2E"
set $accent1 "#DDB6F2"
set $accent2 "#F5C2E7"
set $accent3 "#E8A2AF"
set $text_color1 "#6E6C7E"
set $text_color2 "#988BA2"
set $text_color3 "#C9CBFF"
set $color_danger "#F28FAD"
set $color_warning "#FAE3B0"
set $color_success "#ABE9B3"

set $mod Mod4
# binds ctrl+space to close the topmost notification
bindsym ctrl+space exec "dunstctl close"
# binds mod+c to launch term in i3 config dir
bindsym $mod+c exec "alacritty --working-directory=.config/i3/"
# binds mod+g to launch keybind documentation
bindsym $mod+g exec "python3 ~/.config/i3/scripts/keybinds/keybinds.py && zathura ~/.config/i3/scripts/keybinds/keybinds_temp.pdf"
# binds mod+b to launch browser
bindsym $mod+b exec $browser 
# binds mod+s to launch settings
bindsym $mod+s exec "gnome-control-center"
bindsym $mod+shift+s exec "flameshot gui"
# binds mod+e to launch files
bindsym $mod+e exec "thunar"
# binds mod+w to switch wallpapers
bindsym $mod+w exec "sh ~/.config/i3/scripts/select.sh"
# media control
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym Print exec "flameshot full -c"
# Restore GNOME's settings
exec_always --no-startup-id /usr/libexec/gnome-settings-daemon-localeexec
exec_always --no-startup-id /usr/lib/gnome-settings-daemon/gsd-xsettings
# Fix a bug in gnome-settings-daemon: http://feeding.cloud.geek.nz/posts/creating-a-modern-tiling-desktop-environment-using-i3/
exec_always --no-startup-id dconf write /org/gnome/settings-daemon/plugins/cursor/active false
exec_always --no-startup-id "picom -f"
exec_always --no-startup-id "wal -s -t -R" #"wal -i $wallpaper_path && python3 ~/.config/i3/scripts/colors.py"
exec_always --no-startup-id "playerctld daemon"
exec --no-startup-id "xrandr -s 1920x1080 -r 144.00"
exec --no-startup-id i3-msg "exec spotify"
exec --no-startup-id i3-msg "exec discord"
exec --no-startup-id i3-msg "exec flameshot"
for_window [class="Spotify"] move to workspace $ws4 
for_window [class="Brave-browser"] move to workspace $ws1
for_window [class="firefox"] move to workspace $ws1
assign [class="discord"] Рєњ $ws3
assign [class="Alacritty"] Рєњ $ws2
for_window [class="Places"]                             floating enable
for_window [class="Tor Browser"]                        floating enable
for_window [class="Gnome-screenshot"]                   floating enable
for_window [class="Screenshot"]                         floating enable
for_window [window_role="pop-up"]                       floating enable
for_window [window_role="bubble"]                       floating enable 
for_window [window_role="task_dialog"]                  floating enable
for_window [window_role="Preferences"]                  floating enable
for_window [window_type="dialog"]                       floating enable 
for_window [window_type="menu"]                         floating enable
title_align center
bindsym $mod+n exec "nm-connection-editor"
gaps inner $gaps
font pango:$font $font_size-2
#bindsym $mod+d exec "sh ~/.config/i3/scripts/rofi.sh" 
bindsym $mod+d exec "i3-dmenu-desktop --dmenu='dmenu -i -p 'App:'' " 
# --- default --- #
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
bindsym XF86AudioRaiseVolume exec --no-startup-id pamixer -i 10 
bindsym XF86AudioLowerVolume exec --no-startup-id pamixer -d 10
bindsym XF86AudioMute exec "sh ~/.config/i3/scripts/volume.sh"
floating_modifier $mod
bindsym $mod+Return exec $term
bindsym $mod+Shift+q kill
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+comma split v
bindsym $mod+period split h
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"
# class                 border          bg              text            indicator
client.focused          $accent1        $accent1        $text_color1    $accent1
client.unfocused        $background     $text_color3    $text_color2    $accent3
default_border pixel 1
default_floating_border normal 2
bar {
        bindsym button1 nop
        status_command i3blocks
        #status_command i3status -c ~/.config/i3status/i3status.conf
        #status_command i3status -c ~/.config/i3status/i3status_without_icons.conf
        #status_command i3status -c ~/.config/i3status/i3status_clean.conf
        i3bar_command i3bar --transparency
        position top
        separator_symbol " " 
        # strip_workspace_numbers true
        font pango:$font $font_size 
        colors {
                background $background_trans
                statusline $accent1
                separator $text_color
                
                #class                  border                  bg                      text    
                focused_workspace       $accent1                $background_trans       $accent1
                active_workspace        $accent1                $background_trans       $accent1
                inactive_workspace      $background_trans       $background_trans       $text_color2
                urgent_workspace        $color_danger           $color_danger           $text_color1
                binding_mode            $color_danger           $color_danger           $text_color1

        }
}
exec --no-startup-id xautolock -time 15 -locker 'i3lock -e -f -i $HOME/.config/wallpapers/rose.jpg' -corners +00-
exec --no-startup-id dunst
