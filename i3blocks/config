[last_commit]
command=python3 ~/.config/i3blocks/scripts/get_last_commit.py
interval=180

[weather]
command=sh ~/.config/i3blocks/scripts/get_weather.sh 
label=Forecast: 
interval=1200

[volume]
command=sh ~/.config/i3blocks/scripts/volume_handler.sh 
label=Volume: 
interval=1

